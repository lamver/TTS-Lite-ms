# Количество параллельных процессов (рекомендуем 48 для вашего сервера)
WORKERS=48
# Таймаут на один запрос (в секундах)
TIMEOUT=120
# Порт сервиса
PORT=8000
# Модель по умолчанию
DEFAULT_MODEL=ru_RU-irina-medium

LANGS="ru en es de fr it pt pl uk tr"
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
QUEUE_NAME=text_to_voice_lite_piter

S3_ENDPOINT=https://..
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=